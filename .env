APP_NAME="BizCRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Baku
APP_URL=

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Database - PostgreSQL for Railway
DB_CONNECTION=pgsql
DB_HOST=
