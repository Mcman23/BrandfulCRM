APP_NAME="BizCRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Baku
APP_URL=http://localhost

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Database - choose one:
# For MySQL (cPanel, shared hosting):
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bizcrm
DB_USERNAME=root
DB_PASSWORD=

# For PostgreSQL (Render.com, Railway):
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=bizcrm
# DB_USERNAME=root
# DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS="noreply@bizcrm.az"
MAIL_FROM_NAME="BizCRM"
